<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Racing Game</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div id="game-container">
        <div id="start-screen" class="screen">
            <h1>🏎️ RACING GAME</h1>
            <p>Use arrow keys to control your car</p>
            <p>Avoid enemy cars and score as much as possible!</p>
            <p>High Score: <span id="start-high-score">0</span></p>
            <button id="start-btn">START GAME</button>
        </div>

        <div id="game-over-screen" class="screen hidden">
            <h1>🚨 GAME OVER</h1>
            <p>Your Score: <span id="final-score">0</span></p>
            <p>High Score: <span id="game-over-high-score">0</span></p>
            <button id="restart-btn">RESTART</button>
        </div>

        <div id="game-ui" class="hidden">
            <div class="score-board">
                <span>Score: <span id="score">0</span></span>
                <span>High Score: <span id="ui-high-score">0</span></span>
            </div>
        </div>

        <canvas id="game-canvas"></canvas>
    </div>

    <script src="game.js"></script>
</body>
</html>
CSS (styles.css)
css
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Arial', sans-serif;
    background: #1a1a2e;
    overflow: hidden;
    height: 100vh;
    width: 100vw;
}

#game-container {
    position: relative;
    width: 100%;
    height: 100%;
}

.screen {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: white;
    z-index: 10;
}

.screen h1 {
    font-size: 4rem;
    margin-bottom: 2rem;
    text-shadow: 2px 2px 4px #000;
    animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
    0%, 100% { text-shadow: 2px 2px 4px #000, 0 0 20px #ff6b6b; }
    50% { text-shadow: 2px 2px 4px #000, 0 0 30px #ff6b6b; }
}

.screen p {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    text-align: center;
}

.screen button {
    margin-top: 2rem;
    padding: 1.2rem 3rem;
    font-size: 1.8rem;
    background: linear-gradient(45deg, #ff6b6b, #ff8e53);
    color: white;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(255, 107, 107, 0.4);
}

.screen button:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(255, 107, 107, 0.6);
}

.hidden {
    display: none !important;
}

#game-ui {
    position: absolute;
    top: 20px;
    left: 0;
    width: 100%;
    z-index: 5;
}

.score-board {
    background: rgba(0, 0, 0, 0.7);
    padding: 15px 30px;
    border-radius: 30px;
    display: flex;
    justify-content: space-between;
    gap: 30px;
    margin: 0 auto;
    width: fit-content;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
}

.score-board span {
    color: white;
    font-size: 1.6rem;
    font-weight: bold;
}

.score-board span:last-child {
    color: #ff6b6b;
}

#score, #final-score {
    color: #ff6b6b;
}

#game-canvas {
    display: block;
    width: 100%;
    height: 100%;
}

@media (max-width: 768px) {
    .screen h1 {
        font-size: 2.5rem;
    }

    .screen p {
        font-size: 1.1rem;
    }

    .screen button {
        padding: 1rem 2rem;
        font-size: 1.3rem;
    }

    .score-board {
        padding: 10px 20px;
        gap: 15px;
    }

    .score-board span {
        font-size: 1.2rem;
    }
}
JavaScript (game.js)
javascript
const canvas = document.getElementById('game-canvas');
const ctx = canvas.getContext('2d');
const startScreen = document.getElementById('start-screen');
const gameOverScreen = document.getElementById('game-over-screen');
const gameUI = document.getElementById('game-ui');
const startBtn = document.getElementById('start-btn');
const restartBtn = document.getElementById('restart-btn');
const scoreElement = document.getElementById('score');
const finalScoreElement = document.getElementById('final-score');
const startHighScoreElement = document.getElementById('start-high-score');
const gameOverHighScoreElement = document.getElementById('game-over-high-score');
const uiHighScoreElement = document.getElementById('ui-high-score');

let canvasWidth, canvasHeight;
let playerCar, enemyCars, road;
let score = 0;
let highScore = 0;
let gameRunning = false;
let animationId;
let keys = {};

// Initialize canvas size
function resizeCanvas() {
    canvasWidth = window.innerWidth;
    canvasHeight = window.innerHeight;
    canvas.width = canvasWidth;
    canvas.height = canvasHeight;
}

// Load high score from Local Storage
function loadHighScore() {
    highScore = localStorage.getItem('racingGameHighScore') || 0;
    startHighScoreElement.textContent = highScore;
    gameOverHighScoreElement.textContent = highScore;
    uiHighScoreElement.textContent = highScore;
}

// Save high score to Local Storage
function saveHighScore() {
    if (score > highScore) {
        highScore = score;
        localStorage.setItem('racingGameHighScore', highScore);
    }
}

// Car class
class Car {
    constructor(x, y, width, height, color) {
        this.x = x;
        this.y = y;
        this.width = width;
        this.height = height;
        this.color = color;
    }

    draw() {
        // Car body
        ctx.fillStyle = this.color;
        ctx.fillRect(this.x, this.y, this.width, this.height);

        // Car windows
        ctx.fillStyle = '#333';
        ctx.fillRect(this.x + 5, this.y + 5, this.width - 10, this.height * 0.2);
        ctx.fillRect(this.x + 5, this.y + this.height - 15, this.width - 10, this.height * 0.15);

        // Car wheels
        ctx.fillStyle = '#000';
        ctx.fillRect(this.x - 2, this.y + 10, 4, 12);
        ctx.fillRect(this.x + this.width - 2, this.y + 10, 4, 12);
        ctx.fillRect(this.x - 2, this.y + this.height - 22, 4, 12);
        ctx.fillRect(this.x + this.width - 2, this.y + this.height - 22, 4, 12);

        // Car lights
        ctx.fillStyle = '#ff0';
        ctx.fillRect(this.x + 3, this.y + 2, 8, 5);
        ctx.fillRect(this.x + this.width - 11, this.y + 2, 8, 5);
    }
}

// Road class
class Road {
    constructor() {
        this.roadWidth = Math.min(400, canvasWidth * 0.8);
        this.roadX = (canvasWidth - this.roadWidth) / 2;
        this.laneCount = 3;
        this.laneWidth = this.roadWidth / this.laneCount;
        this.lineOffset = 0;
        this.lineSpeed = 8;
    }

    draw() {
        // Road background
        ctx.fillStyle = '#333';
        ctx.fillRect(this.roadX, 0, this.roadWidth, canvasHeight);

        // Road borders
        ctx.fillStyle = '#fff';
        ctx.fillRect(this.roadX - 5, 0, 5, canvasHeight);
        ctx.fillRect(this.roadX + this.roadWidth, 0, 5, canvasHeight);

        // Lane dividers
        ctx.fillStyle = '#fff';
        for (let i = 1; i < this.laneCount; i++) {
            const laneX = this.roadX + i * this.laneWidth;
            
            // Draw moving lane lines
            for (let y = -50; y < canvasHeight; y += 60) {
                ctx.fillRect(laneX - 2, y + this.lineOffset, 4, 40);
            }
        }

        // Grass on sides
        ctx.fillStyle = '#2d5a2d';
        ctx.fillRect(0, 0, this.roadX, canvasHeight);
        ctx.fillRect(this.roadX + this.roadWidth, 0, canvasWidth - (this.roadX + this.roadWidth), canvasHeight);
    }

    update() {
        this.lineOffset += this.lineSpeed;
        if (this.lineOffset >= 60) {
            this.lineOffset = 0;
        }
    }
}

// Initialize game
function initGame() {
    resizeCanvas();
    loadHighScore();

    playerCar = new Car(
        canvasWidth / 2 - 25,
        canvasHeight - 120,
        50,
        80,
        '#ff6b6b'
    );

    road = new Road();
    enemyCars = [];
    score = 0;
    scoreElement.textContent = score;
    uiHighScoreElement.textContent = highScore;
}

// Create enemy car
function createEnemyCar() {
    const lane = Math.floor(Math.random() * road.laneCount);
    const laneX = road.roadX + lane * road.laneWidth + (road.laneWidth - 50) / 2;
    const colors = ['#4ecdc4', '#ff793f', '#a8e063', '#56ab2f', '#07d3f0', '#e056fd'];
    const color = colors[Math.floor(Math.random() * colors.length)];

    const enemy = new Car(laneX, -100, 50, 80, color);
    enemy.speed = 3 + Math.random() * 4;
    enemyCars.push(enemy);
}

// Update enemy cars
function updateEnemyCars() {
    for (let i = 0; i < enemyCars.length; i++) {
        enemyCars[i].y += enemyCars[i].speed;

        // Remove cars that passed the screen
        if (enemyCars[i].y > canvasHeight) {
            enemyCars.splice(i, 1);
            i--;
            score += 10;
            scoreElement.textContent = score;
        }
    }

    // Create new enemy cars randomly
    if (Math.random() < 0.02 + (score * 0.0001)) {
        createEnemyCar();
    }
}

// Check collision
function checkCollision(car1, car2) {
    return car1.x < car2.x + car2.width &&
           car1.x + car1.width > car2.x &&
           car1.y < car2.y + car2.height &&
           car1.y + car1.height > car2.y;
}

// Update player car
function updatePlayerCar() {
    const speed = 7;

    if (keys['ArrowLeft'] && playerCar.x > road.roadX + 5) {
        playerCar.x -= speed;
    }
    if (keys['ArrowRight'] && playerCar.x < road.roadX + road.roadWidth - playerCar.width - 5) {
        playerCar.x += speed;
    }
    if (keys['ArrowUp'] && playerCar.y > canvasHeight * 0.3) {
        playerCar.y -= speed;
    }
    if (keys['ArrowDown'] && playerCar.y < canvasHeight - playerCar.height - 10) {
        playerCar.y += speed;
    }
}

// Check all collisions
function checkAllCollisions() {
    for (let enemy of enemyCars) {
        if (checkCollision(playerCar, enemy)) {
            return true;
        }
    }
    return false;
}

// Draw game
function drawGame() {
    ctx.clearRect(0, 0, canvasWidth, canvasHeight);

    road.draw();
    playerCar.draw();

    for (let enemy of enemyCars) {
        enemy.draw();
    }
}

// Update game
function updateGame() {
    road.update();
    updatePlayerCar();
    updateEnemyCars();

    if (checkAllCollisions()) {
        gameOver();
    }
}

// Game loop
function gameLoop() {
    if (!gameRunning) return;

    drawGame();
    updateGame();

    animationId = requestAnimationFrame(gameLoop);
}

// Start game
function startGame() {
    initGame();
    startScreen.classList.add('hidden');
    gameOverScreen.classList.add('hidden');
    gameUI.classList.remove('hidden');
    gameRunning = true;
    gameLoop();
}

// Game over
function gameOver() {
    gameRunning = false;
    saveHighScore();

    cancelAnimationFrame(animationId);

    gameUI.classList.add('hidden');
    gameOverScreen.classList.remove('hidden');
    finalScoreElement.textContent = score;
    gameOverHighScoreElement.textContent = highScore;
}

// Restart game
function restartGame() {
    startGame();
}

// Event listeners
startBtn.addEventListener('click', startGame);
restartBtn.addEventListener('click', restartGame);

window.addEventListener('resize', () => {
    resizeCanvas();
    if (!gameRunning) {
        road = new Road();
        playerCar = new Car(
            canvasWidth / 2 - 25,
            canvasHeight - 120,
            50,
            80,
            '#ff6b6b'
        );
    }
});

window.addEventListener('keydown', (e) => {
    keys[e.key] = true;
    if (e.key === 'ArrowUp' || e.key === 'ArrowDown' || e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
        e.preventDefault();
    }
});

window.addEventListener('keyup', (e) => {
    keys[e.key] = false;
});

// Initialize on load
initGame();